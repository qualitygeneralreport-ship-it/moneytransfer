# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-app-name.railway.app,localhost
CORS_ALLOWED_ORIGINS=https://your-frontend-url.web.app,http://localhost:5173

# Database URL (Provided automatically by Railway if linked)
DATABASE_URL=postgres://user:password@host:port/dbname
